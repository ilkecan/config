# https://direnv.net/man/direnv-stdlib.1.html

strict_env

watch_file ./nix/flake/per-system/pre-commit.nix

use flake

CACHIX_AUTH_TOKEN="$(cat ~/.config/sops-nix/secrets/cachix-auth-token)"
export CACHIX_AUTH_TOKEN

with_priority() {
  local i=$1; shift
  local x
  for x in "$@"; do
    printf "%s?priority=%d\n" "$x" "$i"
    ((i++))
  done
}

substituters=(
  https://nix-community.cachix.org

  https://cache.numtide.com
  https://nix-gaming.cachix.org

  # NUR
  https://ilkecan.cachix.org
  https://rycee.cachix.org
)

keys=(
  nix-community.cachix.org-1:mB9FSh9qf2dCimDSUo8Zy7bkq5CX+/rkCWyvRCYg3Fs=

  niks3.numtide.com-1:DTx8wZduET09hRmMtKdQDxNNthLQETkc/yaX7M4qK0g=
  nix-gaming.cachix.org-1:nbjlureqMbRAxR1gJ/f3hxemL9svXaZF/Ees8vCUUs4=

  ilkecan.cachix.org-1:hXb7Vo9EzaXiEb0elvG6Tt5TrP3zrcadyoX8c+lbeCY=
  rycee.cachix.org-1:TiiXyeSk0iRlzlys4c7HiXLkP3idRf20oQ/roEUAh/A=
)

# default priority is 40, see: https://nix.dev/manual/nix/2.18/command-ref/conf-file#conf-substituters
mapfile -t substituters_p < <(with_priority 41 "${substituters[@]}")

NIX_CONFIG="
  extra-substituters = ${substituters_p[*]}
  extra-trusted-public-keys = ${keys[*]}
"
export NIX_CONFIG
